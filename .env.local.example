# Copy this file to .env.local and fill in your Supabase project values.
# Find these at: Supabase Dashboard > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Mapbox access token, used server-side only for geocoding via the Search
# Box Suggest/Retrieve API (lib/geocoding.ts) and driving-distance routing
# (lib/routing.ts). Create one at:
# https://console.mapbox.com/account/access-tokens/
# A secret token (sk.*) is preferred over a public token (pk.*) since these
# calls never happen in the browser. Make sure the token has the SEARCH
# scope enabled — required for the /search/searchbox/v1 endpoints.
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token
