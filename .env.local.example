# Copy this file to .env.local and fill in your Supabase project values.
# Find these at: Supabase Dashboard > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — never expose publicly. Used only by the automation endpoint.
# Find at: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret shared between the Gmail Apps Script and the /api/import-automated endpoint.
# Generate with: openssl rand -hex 32
AUTOMATION_SECRET=generate-with-openssl-rand-hex-32
